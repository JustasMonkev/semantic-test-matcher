{
  "name": "cli-ai-tool",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "rbt": "dist/cli.js"
  },
  "allowScripts": {
    "node-llama-cpp": true
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "node-llama-cpp": "^3.19.0"
  }
}
