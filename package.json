{
  "name": "semantic-test-matcher",
  "private": false,
  "version": "0.1.0",
  "description": "Rank likely test files for source changes using local GGUF embeddings.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JustasMonkev/semantic-test-matcher.git"
  },
  "bugs": {
    "url": "https://github.com/JustasMonkev/semantic-test-matcher/issues"
  },
  "homepage": "https://github.com/JustasMonkev/semantic-test-matcher#readme",
  "keywords": [
    "test-selection",
    "semantic-search",
    "embeddings",
    "gguf",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "rbt": "dist/cli.js"
  },
  "allowScripts": {
    "node-llama-cpp": true
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "node-llama-cpp": "^3.19.0"
  }
}
